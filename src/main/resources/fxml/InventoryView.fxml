<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" prefWidth="450" prefHeight="550"
      style="-fx-background-color: #f5e6b5; -fx-border-color: #3e2723; -fx-border-width: 6; -fx-background-radius: 35; -fx-border-radius: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 8);"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.controller.InventoryController">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <VBox alignment="CENTER" spacing="5">
        <Label text="MA GRANGE" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #3e2723;"/>
        <Label text="Gestion des stocks" style="-fx-text-fill: #8d6e63; -fx-font-style: italic;"/>
    </VBox>

    <ListView fx:id="inventoryListView" VBox.vgrow="ALWAYS"
              style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-border-color: #d7ccc8; -fx-border-width: 2;"/>

    <HBox spacing="20" alignment="CENTER">
        <Button text="💰 TOUT VENDRE" onAction="#handleSellAll"
                HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="btn-sell"
                style="-fx-font-size: 16; -fx-padding: 12;"/>

        <Button text="RETOUR" onAction="#handleClose"
                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: bold;"/>
    </HBox>
</VBox>