<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="TOP_CENTER" prefWidth="350"
      style="-fx-background-color: #2c3e50; -fx-border-color: #27ae60; -fx-border-width: 3; -fx-background-radius: 10; -fx-border-radius: 10;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="main.java.controller.PlantationController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="SEMER" style="-fx-text-fill: #27ae60; -fx-font-size: 22; -fx-font-weight: bold;"/>
    <Label fx:id="infoLabel" text="Sélectionnez vos graines" style="-fx-text-fill: white;"/>

    <ScrollPane fitToWidth="true" prefHeight="250" style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox fx:id="seedContainer" spacing="10"/>
    </ScrollPane>

    <Button text="ANNULER" onAction="#handleClose" maxWidth="Infinity"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
</VBox>