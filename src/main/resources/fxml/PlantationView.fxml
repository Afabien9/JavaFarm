<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" prefWidth="300"
      style="-fx-background-color: #f5e6b5; -fx-border-color: #3e2723; -fx-border-width: 4; -fx-background-radius: 25; -fx-border-radius: 20;"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="main.java.controller.PlantationController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="PLANTER UNE GRAINE" style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #3e2723;"/>

    <ListView fx:id="seedsInInventoryList" prefHeight="200"
              style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 10;"/>

    <Button text="PLANTER" onAction="#handlePlant" maxWidth="Infinity"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 10; -fx-cursor: hand;"/>

    <Button text="ANNULER" onAction="#handleCancel"
            style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-underline: true; -fx-cursor: hand;"/>
</VBox>