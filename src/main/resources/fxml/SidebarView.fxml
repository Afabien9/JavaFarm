<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="sidebarRoot" spacing="15" prefWidth="280"
      style="-fx-background-color: #2c3e50;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="main.java.controller.SidebarController">

    <padding><Insets top="20" right="15" bottom="20" left="15"/></padding>

    <Label fx:id="walletLabel" text="Argent: 0 €" style="-fx-text-fill: #f1c40f; -fx-font-size: 18; -fx-font-weight: bold;"/>

    <Separator/>

    <Label text="MODE CONSTRUCTION" style="-fx-text-fill: white; -fx-font-size: 10;"/>
    <HBox spacing="10">
        <Button text="TERRE" onAction="#handleModePlots" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #8b4513; -fx-text-fill: white;"/>
        <Button text="ENCLOS" onAction="#handleModeEnclosures" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;"/>
    </HBox>
    <ToggleButton fx:id="buildToggle" text="ACTIVER CONSTRUCTION (B)" onAction="#handleToggleBuild" maxWidth="Infinity"/>

    <Separator/>

    <Label text="INVENTAIRE" style="-fx-text-fill: white;"/>
    <ListView fx:id="inventoryListView" VBox.vgrow="ALWAYS" style="-fx-background-color: #34495e;"/>

    <Button text="BOUTIQUE" onAction="#handleOpenShop" maxWidth="Infinity" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
    <Button text="TOUT VENDRE" onAction="#sellAll" maxWidth="Infinity" style="-fx-background-color: #e67e22; -fx-text-fill: white;"/>
</VBox>