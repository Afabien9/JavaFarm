<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="sidebarRoot" spacing="20" prefWidth="900" styleClass="sidebar"
      xmlns:fx="http://javafx.com/fxml" fx:controller="main.java.controller.SidebarController"
      style="-fx-background-color: #2c3e50; -fx-border-color: #1a252f; -fx-border-width: 0 0 0 4;">

    <padding>
        <Insets top="25" right="20" bottom="25" left="20"/>
    </padding>

    <VBox spacing="10" alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 15; -fx-background-radius: 15;">
        <Label fx:id="walletLabel" text="0 €"
               style="-fx-text-fill: #f1c40f; -fx-font-size: 26; -fx-font-weight: bold;"/>
        <Label fx:id="weatherLabel" text="SOLEIL"
               style="-fx-text-fill: #3498db; -fx-font-weight: bold; -fx-font-size: 12; -fx-letter-spacing: 2;"/>
    </VBox>

    <VBox spacing="5" style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 10; -fx-background-radius: 10;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="NIVEAU" style="-fx-text-fill: #bdc3c7; -fx-font-size: 10; -fx-font-weight: bold;"/>
            <Label fx:id="levelLabel" text="1" style="-fx-text-fill: #2ecc71; -fx-font-size: 18; -fx-font-weight: bold;"/>
        </HBox>
        <ProgressBar fx:id="xpBar" progress="0.0" maxWidth="Infinity" prefHeight="10"
                     style="-fx-accent: #2ecc71;"/>
        <Label fx:id="xpLabel" text="0 / 100 XP" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10;"/>
    </VBox>

    <Separator opacity="0.2"/>

    <VBox spacing="15" VBox.vgrow="ALWAYS">
        <Label text="GESTION" style="-fx-font-weight: bold; -fx-text-fill: #bdc3c7; -fx-font-size: 11; -fx-letter-spacing: 1;"/>

        <Button text="📦 MA GRANGE" onAction="#handleOpenInventory" maxWidth="Infinity"
                style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Button text="🛒 BOUTIQUE" onAction="#handleOpenShop" maxWidth="Infinity"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Button text="🛠 AMÉLIORATIONS" onAction="#handleOpenUpgrades" maxWidth="Infinity"
                style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50; -fx-font-size: 14; -fx-padding: 12; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Button fx:id="debugXpBtn" text="⚙️ ADD XP (DEBUG)" onAction="#handleDebugAddXP" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 11; -fx-border-color: #7f8c8d; -fx-border-radius: 5; -fx-cursor: hand;"/>
        <Button text="❓ AIDE TOUCHES" onAction="#handleOpenHelp" maxWidth="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button text="🏪 MARCHÉ LOCAL" onAction="#handleOpenMarket" maxWidth="Infinity"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 10; -fx-cursor: hand;"/>
    </VBox>

    <Separator opacity="0.2"/>

    <VBox alignment="BOTTOM_CENTER" spacing="10">
        <Button text="💰 TOUT VENDRE" onAction="#handleSellAll" maxWidth="Infinity"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 16; -fx-padding: 15; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Label text="Version 1.0.4 - Alpha" style="-fx-text-fill: #5d6d7e; -fx-font-size: 9;"/>
    </VBox>

</VBox>