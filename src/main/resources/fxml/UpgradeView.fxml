<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox spacing="20" alignment="TOP_CENTER" prefWidth="500" prefHeight="600"
      style="-fx-background-color: #2c3e50; -fx-border-color: #f1c40f; -fx-border-width: 3; -fx-border-radius: 10; -fx-background-radius: 10;"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="main.java.controller.UpgradeController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_RIGHT">
        <Button text="X" onAction="#handleClose"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;"/>
    </HBox>

    <Label text="CENTRE D'AMÉLIORATIONS"
           style="-fx-text-fill: #f1c40f; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <Separator style="-fx-opacity: 0.3;"/>

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
        <VBox fx:id="upgradeContainer" spacing="15">
        </VBox>
    </ScrollPane>

    <HBox alignment="CENTER" spacing="20">
        <Label fx:id="walletLabel" text="Argent : 0€" style="-fx-text-fill: white; -fx-font-size: 16;"/>
    </HBox>

</VBox>