<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" prefWidth="450" prefHeight="550"
      style="-fx-background-color: #f5e6b5; -fx-border-color: #3e2723; -fx-border-width: 5; -fx-background-radius: 30; -fx-border-radius: 30;"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="main.java.controller.ShopController">

    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>

    <Label text="BOUTIQUE DE LA FERME" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #3e2723;"/>
    <Label fx:id="shopWalletLabel" style="-fx-background-color: #3e2723; -fx-text-fill: #f1c40f; -fx-padding: 8 20; -fx-background-radius: 15; -fx-font-weight: bold;"/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <tabs>
            <Tab text="🌾 GRAINES">
                <VBox spacing="15" style="-fx-padding: 15 0 0 0;">
                    <ListView fx:id="seedsListView" VBox.vgrow="ALWAYS" styleClass="list-view"/>
                    <Button text="ACHETER" onAction="#handleBuy" maxWidth="Infinity" styleClass="btn-shop"/>
                </VBox>
            </Tab>
            <Tab text="🐄 ANIMAUX">
                <VBox spacing="15" style="-fx-padding: 15 0 0 0;">
                    <ListView fx:id="animalsListView" VBox.vgrow="ALWAYS" styleClass="list-view"/>
                    <Button text="ACHETER" onAction="#handleBuy" maxWidth="Infinity" styleClass="btn-shop"/>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>

    <Button text="RETOUR" onAction="#handleCloseShop" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 15;"/>
</VBox>