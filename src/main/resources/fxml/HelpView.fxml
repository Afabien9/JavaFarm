<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefWidth="450" style="-fx-background-color: #2c3e50; -fx-padding: 30; -fx-border-color: #f1c40f; -fx-border-width: 3; -fx-background-radius: 20; -fx-border-radius: 20;" xmlns:fx="http://javafx.com/fxml" fx:controller="main.java.controller.HelpController">

    <Label text="📖 GUIDE DU FERMIER" style="-fx-text-fill: #f1c40f; -fx-font-size: 24; -fx-font-weight: bold;" alignment="CENTER" maxWidth="Infinity"/>

    <VBox spacing="10">
        <Label text="⌨️ TOUCHES CLAVIER" style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 16;"/>
        <Label text="[ B ] : Mode Construction (Placer champs/enclos)" style="-fx-text-fill: #bdc3c7;"/>
        <Label text="[ X ] : Mode Destruction (Supprimer avec remboursement)" style="-fx-text-fill: #bdc3c7;"/>
        <Label text="[ M ] : Mode Debug (Ajout d'argent et XP)" style="-fx-text-fill: #bdc3c7;"/>
    </VBox>

    <Separator opacity="0.3"/>

    <VBox spacing="10">
        <Label text="📜 RÈGLES DU JEU" style="-fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 16;"/>
        <Label text="1. Gagne de l'XP en récoltant pour monter de niveau." style="-fx-text-fill: #bdc3c7;" wrapText="true"/>
        <Label text="2. Le niveau débloque de nouveaux animaux et augmente la limite de bâtiments." style="-fx-text-fill: #bdc3c7;" wrapText="true"/>
        <Label text="3. Les animaux doivent être nourris pour commencer à produire." style="-fx-text-fill: #bdc3c7;" wrapText="true"/>
        <Label text="4. Le prix des bâtiments augmente à chaque achat !" style="-fx-text-fill: #bdc3c7;" wrapText="true"/>
    </VBox>

    <Button text="C'EST COMPRIS !" onAction="#handleClose" maxWidth="Infinity"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 10; -fx-cursor: hand;"/>
</VBox>