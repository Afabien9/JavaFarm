<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" prefWidth="250"
      style="-fx-background-color: #2c3e50; -fx-border-color: #f1c40f; -fx-border-width: 2;"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="main.java.controller.AnimalInteractionController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label fx:id="animalNameLabel" style="-fx-text-fill: #f1c40f; -fx-font-weight: bold; -fx-font-size: 16;"/>
    <Label fx:id="statusLabel" style="-fx-text-fill: white;"/>
    <Label fx:id="needsLabel" style="-fx-text-fill: #bdc3c7; -fx-font-size: 11;"/>

    <Button fx:id="feedButton" text="Nourrir l'animal" onAction="#handleFeed"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
</VBox>