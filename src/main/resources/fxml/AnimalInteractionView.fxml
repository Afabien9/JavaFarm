<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" prefWidth="280"
      style="-fx-background-color: #f5e6b5; -fx-border-color: #3e2723; -fx-border-width: 4; -fx-background-radius: 20; -fx-border-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="main.java.controller.AnimalInteractionController">

    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label fx:id="animalNameLabel"
           style="-fx-text-fill: #3e2723; -fx-font-weight: bold; -fx-font-size: 18;"/>

    <Separator opacity="0.3" maxWidth="150"/>

    <VBox alignment="CENTER" spacing="5">
        <Label fx:id="statusLabel"
               style="-fx-text-fill: #5d4037; -fx-font-weight: bold;"/>
        <Label fx:id="needsLabel"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 12; -fx-font-style: italic;"/>
    </VBox>

    <Button fx:id="feedButton" text="Nourrir l'animal" onAction="#handleFeed"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 10 20; -fx-cursor: hand;"/>

    <Button text="Fermer" onAction="#handleClose"
            style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-size: 11; -fx-underline: true; -fx-cursor: hand;"/>
</VBox>